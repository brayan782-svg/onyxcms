{
  "entities": {
    "License": {
      "title": "License",
      "description": "A master license generated by the admin.",
      "type": "object",
      "properties": {
        "key": {
          "type": "string",
          "description": "The unique license key (e.g. ONYX-1234-ABCD-5678)."
        },
        "email": {
          "type": "string",
          "description": "The email of the customer."
        },
        "domain": {
          "type": "string",
          "description": "The domain authorized by this license."
        },
        "status": {
          "type": "string",
          "enum": ["active", "revoked"]
        },
        "type": {
          "type": "string",
          "enum": ["standard", "premium", "enterprise"]
        },
        "createdAt": {
          "type": "timestamp"
        },
        "updatedAt": {
          "type": "timestamp"
        }
      },
      "required": ["key", "email", "domain", "status", "type", "createdAt"]
    }
  },
  "firestore": {
    "licenses/{licenseKey}": {
      "schema": {
        "$ref": "#/entities/License"
      },
      "description": "Stores the generated master licenses. The document ID is the license key."
    }
  }
}
