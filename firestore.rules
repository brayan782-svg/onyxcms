rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if true;
    }
    // Admin helper
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "brayan782@gmail.com";
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Validation for License
    function isValidLicense(data) {
      return data.keys().hasAll(['key', 'email', 'domain', 'status', 'type', 'createdAt']) &&
             data.key is string && data.key.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.domain is string && data.domain.size() <= 100 &&
             data.status in ['active', 'revoked'] &&
             data.type in ['trial', 'unlimited', 'reseller'];
    }

    match /licenses/{licenseKey} {
      allow get, list: if true;
      allow write: if request.auth != null;
    }
    
    match /license_logs/{logId} {
      allow read, write: if request.auth != null;
    }
    
    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == "brayan782@gmail.com";
    }
  }
}
